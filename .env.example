# SQLAlchemy database URL
# SQLite (local):     sqlite:///drinkingBuddy.db
# SQLite (absolute):  sqlite:////data/drinkingBuddy.db
DB_PATH=sqlite:////data/drinkingBuddy.db

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# LDAP
LDAP_URL=ldap://freeipa.lan.posttenebraslab.ch
LDAP_USER_SEARCH_BASE=cn=users,cn=accounts,dc=posttenebraslab,dc=ch
LDAP_GROUP_SEARCH_BASE=cn=groups,cn=accounts,dc=posttenebraslab,dc=ch
